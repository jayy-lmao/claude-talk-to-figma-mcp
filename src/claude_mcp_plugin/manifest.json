{
  "name": "Claude Talk to Figma Plugin",
  "id": "claude-mcp-plugin",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "editorType": [
    "figma",
    "figjam"
  ],
  "permissions": ["teamlibrary"],
  "networkAccess": {
    "allowedDomains": [
      "http://localhost:3055",
      "ws://localhost:3055"
    ],
    "reasoning": "Connects to a local WebSocket server that bridges communication between this Figma plugin and AI tools like Claude."
  },
  "documentAccess": "dynamic-page",
  "enableProposedApi": false,
  "enablePrivatePluginApi": false
}